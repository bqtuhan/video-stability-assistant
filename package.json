{
  "name": "video-stability-assistant",
  "version": "1.1.0",
  "description": "Real-time browser extension for video playback stability monitoring, scoring, freeze prediction, and actionable advisories.",
  "author": "bqtuhan",
  "license": "Apache-2.0",
  "homepage": "https://github.com/bqtuhan/video-stability-assistant",
  "repository": {
    "type": "git",
    "url": "https://github.com/bqtuhan/video-stability-assistant.git"
  },
  "bugs": {
    "url": "https://github.com/bqtuhan/video-stability-assistant/issues"
  },
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },

  "scripts": {
    "build":          "cross-env NODE_ENV=production BROWSER=chrome webpack --config webpack.config.js",
    "build:firefox":  "cross-env NODE_ENV=production BROWSER=firefox webpack --config webpack.config.js",
    "build:all":      "npm run build && npm run build:firefox",

    "dev":            "cross-env NODE_ENV=development BROWSER=chrome webpack --config webpack.config.js --watch",
    "dev:firefox":    "cross-env NODE_ENV=development BROWSER=firefox webpack --config webpack.config.js --watch",

    "type-check":     "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",

    "lint":           "eslint src --ext .ts,.tsx --max-warnings 0",
    "lint:fix":       "eslint src --ext .ts,.tsx --fix",

    "test":           "jest --passWithNoTests",
    "test:watch":     "jest --watch --passWithNoTests",
    "test:coverage":  "jest --coverage --passWithNoTests",

    "clean":          "rimraf dist",
    "prebuild":       "npm run clean",

    "validate-weights": "node -e \"const s=require('./src/engines/scoring'); ['balanced','live','vod'].forEach(m=>{const w=s.getWeights(m);const sum=Object.values(w).reduce((a,b)=>a+b,0);console.log(m,sum.toFixed(3),sum===1?'✅':'❌');});\"",

    "zip":            "node scripts/zip.js",
    "zip:firefox":    "node scripts/zip.js --browser firefox"
  },

  "dependencies": {
    "react":            "^18.3.1",
    "react-dom":        "^18.3.1"
  },

  "devDependencies": {
    "@types/chrome":          "^0.0.279",
    "@types/node":            "^22.10.1",
    "@types/react":           "^18.3.12",
    "@types/react-dom":       "^18.3.1",

    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser":        "^8.18.0",
    "eslint":                           "^9.17.0",
    "eslint-plugin-react":              "^7.37.3",
    "eslint-plugin-react-hooks":        "^5.1.0",

    "copy-webpack-plugin":         "^14.0.0",
    "cross-env":                   "^7.0.3",
    "css-loader":                  "^7.1.2",
    "fork-ts-checker-webpack-plugin": "^9.0.2",
    "html-webpack-plugin":         "^5.6.3",
    "mini-css-extract-plugin":     "^2.9.2",
    "terser-webpack-plugin":       "^5.3.11",
    "ts-loader":                   "^9.5.1",
    "typescript":                  "^5.7.2",
    "webpack":                     "^5.97.1",
    "webpack-cli":                 "^5.1.4",

    "@jest/globals":              "^29.7.0",
    "jest":                       "^29.7.0",
    "jest-environment-jsdom":     "^30.3.0",
    "ts-jest":                    "^29.2.5",

    "rimraf":                     "^6.0.1",
    "archiver":                   "^7.0.1"
  },

  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "moduleNameMapper": {
      "^@/(.*)$":           "<rootDir>/src/$1",
      "^@types/(.*)$":      "<rootDir>/src/types/$1",
      "^@utils/(.*)$":      "<rootDir>/src/utils/$1",
      "^@engines/(.*)$":    "<rootDir>/src/engines/$1",
      "^@components/(.*)$": "<rootDir>/src/components/$1"
    },
    "setupFiles": [
      "<rootDir>/src/__tests__/setup.ts"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "src/**/*.tsx",
      "!src/**/*.d.ts",
      "!src/**/index.ts",
      "!src/**/index.tsx"
    ],
    "coverageThreshold": {
      "global": {
        "branches":   10,
        "functions":  20,
        "lines":      20,
        "statements": 20
      }
    }
  },

  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions"
  ]
}
